{
  "name": "offdash",
  "displayName": "OffDash",
  "description": "Paste-ready work briefs from git evidence — no dashboard, just your editor and clipboard.",
  "version": "0.1.0",
  "publisher": "tokenlaxx",
  "license": "Apache-2.0",
  "icon": "images/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/Tokenlaxx/cursor-calgary-2026-june-micro-hackathon"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "activationEvents": ["onCommand:offdash.standup", "onCommand:offdash.stakeholder"],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "offdash.standup",
        "title": "OffDash: Standup Brief (from git evidence)",
        "category": "OffDash"
      },
      {
        "command": "offdash.stakeholder",
        "title": "OffDash: Stakeholder Update (from git evidence)",
        "category": "OffDash"
      },
      {
        "command": "offdash.copyLastBrief",
        "title": "OffDash: Copy Last Brief to Clipboard",
        "category": "OffDash"
      }
    ],
    "configuration": {
      "title": "OffDash",
      "properties": {
        "offdash.apiKey": {
          "type": "string",
          "default": "",
          "description": "OpenAI-compatible API key. Falls back to OPENROUTER_API_KEY, OFFDASH_API_KEY, or OPENAI_API_KEY env vars.",
          "order": 1
        },
        "offdash.apiBaseUrl": {
          "type": "string",
          "default": "https://openrouter.ai/api/v1",
          "description": "OpenAI-compatible API base URL.",
          "order": 2
        },
        "offdash.model": {
          "type": "string",
          "default": "openrouter/free",
          "description": "Model id for brief generation. Default uses OpenRouter free-model routing.",
          "order": 3
        },
        "offdash.lookbackHours": {
          "type": "number",
          "default": 24,
          "minimum": 1,
          "maximum": 168,
          "description": "How many hours of git activity to include.",
          "order": 4
        }
      }
    }
  },
  "scripts": {
    "build": "tsc -p .",
    "watch": "tsc -watch -p .",
    "test": "node --test dist/test/*.test.js",
    "pretest": "npm run build",
    "package": "npm run build && npx --yes @vscode/vsce package --no-dependencies",
    "vscode:prepublish": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.8.3"
  }
}
